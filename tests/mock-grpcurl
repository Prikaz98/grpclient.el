#!/bin/sh
# Mock grpcurl for tests — returns canned data based on arguments.
# Usage: grpcurl [flags...] <server> list [<service>]
#        grpcurl [flags...] [-msg-template] <server> describe <symbol>

msg_template=0
args=""
for a in "$@"; do
  case "$a" in
    -plaintext|-vv|-insecure|-emit-defaults|-expand-headers) ;;
    -msg-template) msg_template=1 ;;
    -*) ;;
    *) args="$args $a" ;;
  esac
done
args="${args# }"

if [ "$msg_template" = 1 ]; then
  case "$args" in
    "localhost:9000 describe hello.HelloService.SayHelloRequest")
      echo "hello.HelloService.SayHelloRequest is a message:"
      echo "message SayHelloRequest {"
      echo "  string greeting = 1;"
      echo "  string name = 2;"
      echo "}"
      echo ""
      echo "Message template:"
      echo '{'
      echo '  "greeting": "",'
      echo '  "name": ""'
      echo '}'
      exit 0
      ;;
    "localhost:9000 describe grpcbin.GRPCBin.DummyUnaryRequest")
      echo "grpcbin.GRPCBin.DummyUnaryRequest is a message:"
      echo "message DummyUnaryRequest {"
      echo "  string fString = 1;"
      echo "  int32 fInt32 = 2;"
      echo "  bool fBool = 3;"
      echo "}"
      echo ""
      echo "Message template:"
      echo '{'
      echo '  "fString": "",'
      echo '  "fInt32": 0,'
      echo '  "fBool": false'
      echo '}'
      exit 0
      ;;
    *)
      echo "ERROR: unexpected args: $args (with -msg-template)"
      exit 1
      ;;
  esac
fi

case "$args" in
  "localhost:9000 list")
    echo "hello.HelloService"
    echo "grpcbin.GRPCBin"
    exit 0
    ;;
  "localhost:9000 describe hello.HelloService")
    echo "hello.HelloService is a service:"
    echo "service HelloService {"
    echo "  rpc SayHello ( .hello.HelloService.SayHelloRequest ) returns ( .hello.HelloService.SayHelloResponse );"
    echo "  rpc SayHelloStream ( .hello.HelloService.SayHelloRequest ) returns ( .hello.HelloService.SayHelloResponse );"
    echo "}"
    exit 0
    ;;
  "localhost:9000 describe grpcbin.GRPCBin")
    echo "grpcbin.GRPCBin is a service:"
    echo "service GRPCBin {"
    echo "  rpc DummyServerStream ( .grpcbin.GRPCBin.DummyServerStreamRequest ) returns ( .grpcbin.GRPCBin.DummyServerStreamResponse );"
    echo "  rpc DummyUnary ( .grpcbin.GRPCBin.DummyUnaryRequest ) returns ( .grpcbin.GRPCBin.DummyUnaryResponse );"
    echo "}"
    exit 0
    ;;
  "localhost:9000 describe hello.HelloService.SayHello")
    echo "hello.HelloService.SayHello is a method:"
    echo "rpc SayHello ( .hello.HelloService.SayHelloRequest ) returns ( .hello.HelloService.SayHelloResponse );"
    exit 0
    ;;
  "localhost:9000 describe hello.HelloService.SayHelloRequest")
    echo "hello.HelloService.SayHelloRequest is a message:"
    echo "message SayHelloRequest {"
    echo "  string greeting = 1;"
    echo "  string name = 2;"
    echo "}"
    exit 0
    ;;
  "unknown:0000 list")
    echo "ERROR: server not found"
    exit 1
    ;;
  *)
    echo "ERROR: unexpected args: $args"
    exit 1
    ;;
esac
